@page "/courses"
@inject TravellersTavern.ViewModels.CoursesViewModel Vm

<h1>@Vm.Title</h1>
<p>@Vm.IntroText</p>

<div class="block-list">
    @foreach (var opt in Vm.Options)
    {
        <article class="info-block">
            <h3>@opt.Title</h3>
            <p>@opt.Description</p>
            @if (!string.IsNullOrEmpty(opt.Href))
            {
                <a href="@opt.Href" target="_blank" rel="noopener noreferrer">
                    <button class="btn">@opt.ButtonText</button>
                </a>
            }
        </article>
    }
</div>

<div class="note">
    <strong>Agenda:</strong> @Vm.CalendarNote
</div>

@code {
    protected override void OnInitialized()
    {
        Vm.Load();
    }
}